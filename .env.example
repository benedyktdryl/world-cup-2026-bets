BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
TRUSTED_ORIGINS=http://localhost:3000

# Local SQLite file (default). On Vercel, use Turso instead.
DB_PATH=./data/world-cup-bets.sqlite
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

ADMIN_EMAILS=admin@example.com
ALLOWED_EMAIL_DOMAINS=example.com

SCRAPER_CONTACT_URL=https://example.com/contact
FLASHSCORE_SOURCE_URL=https://www.flashscore.com/football/world/world-championship/
FLASHSCORE_COMPETITION_NAME=World Cup 2026
FLASHSCORE_BASE_URL=https://www.flashscore.com

# Local Bun server scheduler. On Vercel, use vercel.json cron + CRON_SECRET.
DAILY_CRAWL_ENABLED=true
DAILY_CRAWL_HOUR=4
DAILY_CRAWL_TIMEZONE=UTC
CRON_SECRET=replace-with-random-cron-secret

PORT=3000
HOST=0.0.0.0
